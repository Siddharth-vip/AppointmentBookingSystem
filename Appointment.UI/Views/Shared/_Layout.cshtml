<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<title>@ViewData["Title"] - Appointment</title>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>

<style>

body{
margin:0;
font-family:Segoe UI;
}

/* NAVBAR (YELLOW AREA FIX) */

.navbar-custom{
position:absolute;
top:0;
width:100%;
display:flex;
justify-content:space-between;
align-items:center;
padding:25px 120px;
z-index:100;
}

.logo{
font-size:24px;
font-weight:bold;
color:white;
}

.menu{
display:flex;
gap:40px;
align-items:center;
}

.menu a{
color:white;
text-decoration:none;
font-size:20px;
}

.register-btn{
border:2px solid white;
padding:10px 25px;
border-radius:30px;
}

</style>

</head>

<body>

<div class="navbar-custom">

<div class="logo">
YourLogo
</div>

<div class="menu">

<a href="/Home/About">About Us</a>

<a href="/Home/Privacy">Privacy</a>

<a href="/Home/Contact">Contact Us</a>

<a href="/Auth/Register" class="register-btn">Register</a>

</div>

</div>

@RenderBody()

</body>
</html>