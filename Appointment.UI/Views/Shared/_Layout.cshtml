@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<title>@ViewData["Title"] - Appointment</title>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>

<style>

body{
margin:0;
font-family:Segoe UI;
}

/* NAVBAR */

.navbar-custom{
position:fixed;
top:0;
width:100%;
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 120px;
background:#1e3a5f;
z-index:100;
}

.logo{
font-size:24px;
font-weight:bold;
color:white;
}

.menu{
display:flex;
gap:30px;
align-items:center;
}

.menu a{
color:white;
text-decoration:none;
font-size:18px;
}

.menu a:hover{
text-decoration:underline;
}

.register-btn{
border:2px solid white;
padding:8px 22px;
border-radius:30px;
}

.username{
color:white;
font-size:18px;
font-weight:500;
}

/* page spacing */
.page-content{
margin-top:100px;
}

</style>

</head>

<body>

<div class="navbar-custom">

<div class="logo">
Doctor Appointment
</div>

<div class="menu">

<a href="/Home/Index">Home</a>
<a href="/Home/About">About Us</a>
<a href="/Home/Privacy">Privacy</a>
<a href="/Home/Contact">Contact Us</a>

@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");
}

@if(userId == null)
{
    <a href="/Auth/Login">Login</a>
    <a href="/Auth/Register" class="register-btn">Register</a>
}
else
{
    <a href="/Dashboard/Index">My Slots</a>

    <span class="username">
        Welcome, @userName
    </span>

    <a href="/Auth/Logout" class="register-btn">Logout</a>
}

</div>

</div>

<div class="page-content">
    @RenderBody()
</div>

</body>
</html>