@{
    ViewData["Title"] = "About";
}

<div class="container mt-5">

<h1 class="text-center mb-4">About Doctor Appointment System</h1>

<p class="text-center text-muted mb-5">
This Doctor Appointment Booking System allows patients to search doctors,
view available time slots, and book appointments online easily.
</p>

<div class="row text-center">

<div class="col-md-4">
<div class="card shadow p-4">
<h4>Find Doctors</h4>
<p>Search doctors by specialization and availability.</p>
</div>
</div>

<div class="col-md-4">
<div class="card shadow p-4">
<h4>Book Appointment</h4>
<p>Choose available slots and book instantly.</p>
</div>
</div>

<div class="col-md-4">
<div class="card shadow p-4">
<h4>Get Treatment</h4>
<p>Visit the doctor and receive professional care.</p>
</div>
</div>

</div>

</div>