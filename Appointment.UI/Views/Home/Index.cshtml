@model HomeIndexViewModel

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success text-center" role="alert">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger text-center" role="alert">
        @TempData["ErrorMessage"]
    </div>
}

@{
    ViewData["Title"] = "Home";
}

<div class="hero-container">

    <!-- LEFT SIDE -->
    <div class="hero-left">

        <h1 class="hero-title">
            Book your appointment
        </h1>

        <p class="hero-text">
            Choose your preferred date and time to check doctor availability.
        </p>

        <a href="/Home/About" class="learn-btn">
            Learn more
        </a>

        <a href="/Doctor" class="find-btn">
            Find Doctors
        </a>

    </div>


    <!-- RIGHT SIDE -->
    <div class="hero-right">

        <!-- ✅ FIXED FORM -->
        <form method="post" action="/Doctor/CheckAvailability" class="appointment-card">

            <h3>Select a date</h3>

            <input type="date"
                   id="date"
                   name="date"
                   class="form-control"
                   required />


            <h3>Select a time</h3>

            <input type="time"
                   id="time"
                   name="time"
                   class="form-control"
                   required />

            <!-- ✅ OPTIONAL (future safe) -->
            <input type="hidden" id="slotId" name="slotId" />
            <input type="hidden" id="doctorId" name="doctorId" />

            <button type="submit" class="book-btn">
                Book now
            </button>

        </form>

    </div>

</div>

@if (Model.IsLoggedIn && !Model.IsAdmin)
{
    <section class="home-summary container mt-4 mb-5">
        @if (Model.ShowBookedJustNow && Model.BookedJustNow != null)
        {
            <div class="just-booked-card mb-4">
                <div class="just-booked-label">Booked just now</div>
                <h4 class="mb-2">@Model.BookedJustNow.DoctorName</h4>
                <p class="mb-1"><strong>Date:</strong> @Model.BookedJustNow.SlotDate.ToString("dd-MM-yyyy")</p>
                <p class="mb-1"><strong>Time:</strong> @Model.BookedJustNow.StartTime - @Model.BookedJustNow.EndTime</p>
                <p class="mb-0"><strong>Status:</strong> @Model.BookedJustNow.Status</p>
            </div>
        }

        <div class="summary-head d-flex justify-content-between align-items-center mb-3">
            <div>
                <h3 class="mb-1">Welcome back, @Model.UserName</h3>
                <p class="text-muted mb-0">Your latest appointment flow snapshot.</p>
            </div>
            <a href="/Dashboard/Index" class="btn btn-outline-primary">Go To My Slots</a>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <div class="card border-success">
                    <div class="card-body">
                        <h5 class="text-success mb-1">Booked Appointments</h5>
                        <div class="display-6">@Model.TotalBookedCount</div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-warning">
                    <div class="card-body">
                        <h5 class="text-warning mb-1">Unavailable / Reschedule</h5>
                        <div class="display-6">@Model.TotalUnavailableCount</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header bg-success text-white">Recent Booked Slots</div>
                    <div class="card-body p-0">
                        @if (Model.RecentBookedSlots.Count == 0)
                        {
                            <p class="p-3 mb-0">No booked slots yet.</p>
                        }
                        else
                        {
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>Doctor</th>
                                        <th>Date</th>
                                        <th>Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var slot in Model.RecentBookedSlots)
                                    {
                                        <tr>
                                            <td>@slot.DoctorName</td>
                                            <td>@slot.SlotDate.ToString("dd-MM-yyyy")</td>
                                            <td>@slot.StartTime - @slot.EndTime</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header bg-warning">Recent Unavailable / Reschedule</div>
                    <div class="card-body p-0">
                        @if (Model.RecentUnavailableSlots.Count == 0)
                        {
                            <p class="p-3 mb-0">No unavailable slots.</p>
                        }
                        else
                        {
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>Doctor</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var slot in Model.RecentUnavailableSlots)
                                    {
                                        <tr>
                                            <td>@slot.DoctorName</td>
                                            <td>@slot.SlotDate.ToString("dd-MM-yyyy")</td>
                                            <td>@slot.Status</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
}


<style>

body{
    margin:0;
    font-family:Segoe UI;
}

/* HERO SECTION */

.hero-container{
    height:90vh;
    display:flex;
    align-items:center;
    justify-content:space-around;
    background:linear-gradient(120deg,#6a5acd,#7b68ee);
}

/* LEFT SIDE */

.hero-left{
    color:white;
    width:45%;
}

.hero-title{
    font-size:60px;
    font-weight:bold;
}

.hero-text{
    margin-top:15px;
    font-size:18px;
}

/* BUTTONS */

.learn-btn{
    display:inline-block;
    margin-top:30px;
    background:#2ecc71;
    padding:15px 40px;
    border-radius:30px;
    color:white;
    text-decoration:none;
    font-size:18px;
}

.find-btn{
    display:inline-block;
    margin-top:20px;
    margin-left:10px;
    background:#ffffff;
    padding:15px 40px;
    border-radius:30px;
    color:#6a5acd;
    text-decoration:none;
    font-size:18px;
    font-weight:bold;
}

/* RIGHT SIDE */

.hero-right{
    width:30%;
}

.appointment-card{
    background:white;
    padding:40px;
    border-radius:20px;
    text-align:center;
    box-shadow:0px 8px 25px rgba(0,0,0,0.2);
}

/* INPUT */

.form-control{
    width:100%;
    padding:12px;
    margin-top:10px;
    margin-bottom:25px;
    border-radius:10px;
    border:1px solid #ccc;
    font-size:16px;
}

/* BUTTON */

.book-btn{
    width:100%;
    padding:15px;
    border:none;
    border-radius:30px;
    background:#2ecc71;
    color:white;
    font-size:18px;
    cursor:pointer;
}

.book-btn:hover{
    background:#27ae60;
}

.home-summary .display-6{
    font-size:2.2rem;
    font-weight:700;
}

.just-booked-card{
    background:linear-gradient(135deg,#1d976c,#2ecc71);
    color:white;
    border-radius:14px;
    padding:20px;
    box-shadow:0 8px 22px rgba(0,0,0,0.15);
}

.just-booked-label{
    display:inline-block;
    background:rgba(255,255,255,0.18);
    border:1px solid rgba(255,255,255,0.35);
    border-radius:999px;
    padding:4px 10px;
    font-size:12px;
    margin-bottom:8px;
    font-weight:600;
}

</style>


<!-- ✅ OPTIONAL DEBUG SCRIPT -->
<script>
document.querySelector("form").addEventListener("submit", function () {
    console.log("Date:", document.getElementById("date").value);
    console.log("Time:", document.getElementById("time").value);
});
</script>