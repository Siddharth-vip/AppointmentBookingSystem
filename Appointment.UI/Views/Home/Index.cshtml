@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success text-center" role="alert">
        @TempData["SuccessMessage"]
    </div>
}

@{
    ViewData["Title"] = "Home";
}

<div class="hero-container">

    <!-- LEFT SIDE -->
    <div class="hero-left">

        <h1 class="hero-title">
            Book your appointment
        </h1>

        <p class="hero-text">
            Choose your preferred date and time to check doctor availability.
        </p>

        <a href="/Home/About" class="learn-btn">
            Learn more
        </a>

        <a href="/Doctor" class="find-btn">
            Find Doctors
        </a>

    </div>


    <!-- RIGHT SIDE -->
    <div class="hero-right">

        <!-- ✅ FIXED FORM -->
        <form method="post" action="/Doctor/CheckAvailability" class="appointment-card">

            <h3>Select a date</h3>

            <input type="date"
                   id="date"
                   name="date"
                   class="form-control"
                   required />


            <h3>Select a time</h3>

            <input type="time"
                   id="time"
                   name="time"
                   class="form-control"
                   required />

            <!-- ✅ OPTIONAL (future safe) -->
            <input type="hidden" id="slotId" name="slotId" />
            <input type="hidden" id="doctorId" name="doctorId" />

            <button type="submit" class="book-btn">
                Book now
            </button>

        </form>

    </div>

</div>


<style>

body{
    margin:0;
    font-family:Segoe UI;
}

/* HERO SECTION */

.hero-container{
    height:90vh;
    display:flex;
    align-items:center;
    justify-content:space-around;
    background:linear-gradient(120deg,#6a5acd,#7b68ee);
}

/* LEFT SIDE */

.hero-left{
    color:white;
    width:45%;
}

.hero-title{
    font-size:60px;
    font-weight:bold;
}

.hero-text{
    margin-top:15px;
    font-size:18px;
}

/* BUTTONS */

.learn-btn{
    display:inline-block;
    margin-top:30px;
    background:#2ecc71;
    padding:15px 40px;
    border-radius:30px;
    color:white;
    text-decoration:none;
    font-size:18px;
}

.find-btn{
    display:inline-block;
    margin-top:20px;
    margin-left:10px;
    background:#ffffff;
    padding:15px 40px;
    border-radius:30px;
    color:#6a5acd;
    text-decoration:none;
    font-size:18px;
    font-weight:bold;
}

/* RIGHT SIDE */

.hero-right{
    width:30%;
}

.appointment-card{
    background:white;
    padding:40px;
    border-radius:20px;
    text-align:center;
    box-shadow:0px 8px 25px rgba(0,0,0,0.2);
}

/* INPUT */

.form-control{
    width:100%;
    padding:12px;
    margin-top:10px;
    margin-bottom:25px;
    border-radius:10px;
    border:1px solid #ccc;
    font-size:16px;
}

/* BUTTON */

.book-btn{
    width:100%;
    padding:15px;
    border:none;
    border-radius:30px;
    background:#2ecc71;
    color:white;
    font-size:18px;
    cursor:pointer;
}

.book-btn:hover{
    background:#27ae60;
}

</style>


<!-- ✅ OPTIONAL DEBUG SCRIPT -->
<script>
document.querySelector("form").addEventListener("submit", function () {
    console.log("Date:", document.getElementById("date").value);
    console.log("Time:", document.getElementById("time").value);
});
</script>