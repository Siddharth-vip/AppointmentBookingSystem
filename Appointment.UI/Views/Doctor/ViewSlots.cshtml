@using Appointment.UI.Models
@model List<TimeSlot>

@{
    ViewData["Title"] = "Doctor Slots";
}

@functions {
    public static string To12Hour(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        if (TimeSpan.TryParse(value, out var timeSpanValue))
        {
            return DateTime.Today.Add(timeSpanValue).ToString("hh:mm tt");
        }

        if (DateTime.TryParse(value, out var dateTimeValue))
        {
            return dateTimeValue.ToString("hh:mm tt");
        }

        return value;
    }
}

<h2>Doctor Available Slots</h2>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Slot ID</th>
            <th>Date</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>

@foreach (var slot in Model)
{
    <tr>

        <td>@slot.SlotId</td>

        <td>@slot.SlotDate.ToString("dd-MM-yyyy")</td>

        <td>@To12Hour(slot.StartTime)</td>

        <td>@To12Hour(slot.EndTime)</td>

        <td>
            @if (slot.IsBooked)
            {
                <span style="color:red;font-weight:bold;">
                    Booked
                </span>
            }
            else
            {
                <span style="color:green;font-weight:bold;">
                    Available
                </span>
            }
        </td>

        <td>
            @if (!slot.IsBooked)
            {
                <!-- ✅ FIX: Use FORM instead of <a> -->
                <form asp-controller="Appointment" asp-action="BookAppointment" method="post" style="display:inline;">
                    
                    <!-- 🔥 VERY IMPORTANT -->
                    <input type="hidden" name="slotId" value="@slot.SlotId" />
                    <input type="hidden" name="doctorId" value="@slot.DoctorId" />

                    <button type="submit" class="btn btn-success">
                        Book Appointment
                    </button>
                </form>
            }
            else
            {
                <button class="btn btn-secondary" disabled>
                    Not Available
                </button>
            }
        </td>

    </tr>
}

    </tbody>

</table>

<a href="/Doctor" class="btn btn-primary">
    Back
</a>