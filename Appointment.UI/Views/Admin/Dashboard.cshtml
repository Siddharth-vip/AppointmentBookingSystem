@model AdminDashboardViewModel

@{
	ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
	<h2>Admin Slot Management</h2>
	<p class="text-muted mb-4">Only admin can create 1-hour slots for 10:00-12:00 and 13:00-17:00.</p>

	@if (TempData["AdminSuccess"] != null)
	{
		<div class="alert alert-success">@TempData["AdminSuccess"]</div>
	}

	@if (TempData["AdminError"] != null)
	{
		<div class="alert alert-danger">@TempData["AdminError"]</div>
	}

	<div class="card">
		<div class="card-header">Doctors</div>
		<div class="card-body p-0">
			<table class="table table-bordered mb-0">
				<thead>
					<tr>
						<th>Doctor ID</th>
						<th>Name</th>
						<th>Specialization</th>
						<th>Experience</th>
						<th>Generate Daily Slots</th>
						<th>Notify For Unavailable Slot (Date + Time)</th>
					</tr>
				</thead>
				<tbody>
				@if (Model.Doctors == null || Model.Doctors.Count == 0)
				{
					<tr>
						<td colspan="6" class="text-center">No doctors found.</td>
					</tr>
				}
				else
				{
					foreach (var doctor in Model.Doctors)
					{
						<tr>
							<td>@doctor.DoctorId</td>
							<td>@doctor.DoctorName</td>
							<td>@doctor.Specialization</td>
							<td>@doctor.Experience years</td>
							<td>
								<form asp-controller="Admin" asp-action="CreateStandardSlots" method="post" class="d-flex gap-2 align-items-center">
									@Html.AntiForgeryToken()
									<input type="hidden" name="doctorId" value="@doctor.DoctorId" />
									<input type="date" name="slotDate" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
									<button type="submit" class="btn btn-primary">Generate</button>
								</form>
							</td>
							<td>
								<form asp-controller="Admin" asp-action="NotifySlotUnavailable" method="post" class="d-flex gap-2 align-items-center">
									@Html.AntiForgeryToken()
									<input type="hidden" name="doctorId" value="@doctor.DoctorId" />
									<input type="date" name="slotDate" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
									<input type="time" name="slotStartTime" class="form-control" step="3600" required />
									<button type="submit" class="btn btn-warning">Notify</button>
								</form>
							</td>
						</tr>
					}
				}
				</tbody>
			</table>
		</div>
	</div>
</div>