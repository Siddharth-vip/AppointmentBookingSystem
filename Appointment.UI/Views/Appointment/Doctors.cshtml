@model List<Doctor>

<!DOCTYPE html>
<html>
<head>

<title>Find Doctors</title>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

</head>

<body>

<div class="container mt-5">

<h2 class="text-center mb-4">Find Doctor</h2>

<form method="get" action="/Appointment/Doctors">

<div class="row mb-4">

<div class="col-md-4">
<input type="text"
name="name"
class="form-control"
placeholder="Search Doctor Name" />
</div>

<div class="col-md-4">
<input type="text"
name="specialization"
class="form-control"
placeholder="Specialization (Cardiology, Dentist...)" />
</div>

<div class="col-md-2">
<input type="number"
name="experience"
class="form-control"
placeholder="Experience" />
</div>

<div class="col-md-2">
<button class="btn btn-primary w-100">
Search
</button>
</div>

</div>

</form>


<div class="row">

@if(Model != null && Model.Count > 0)
{
foreach(var doctor in Model)
{

<div class="col-md-4 mb-4">

<div class="card p-3">

<h4>@doctor.DoctorName</h4>

<p>Specialization: @doctor.Specialization</p>

<p>Experience: @doctor.Experience Years</p>

<p>Phone: @doctor.Phone</p>

<a href="/Appointment/Book?doctorId=@doctor.DoctorId"
class="btn btn-success">

Book Appointment

</a>

</div>

</div>

}
}
else
{
<h4 class="text-center">No Doctors Found</h4>
}

</div>

</div>

</body>
</html>