@using Appointment.UI.Models
@model Appointment

@{
    ViewData["Title"] = "Book Appointment";
    List<TimeSlot>? slots = ViewBag.Slots as List<TimeSlot>;
}

@functions {
    public static string To12Hour(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        if (TimeSpan.TryParse(value, out var timeSpanValue))
        {
            return DateTime.Today.Add(timeSpanValue).ToString("hh:mm tt");
        }

        if (DateTime.TryParse(value, out var dateTimeValue))
        {
            return dateTimeValue.ToString("hh:mm tt");
        }

        return value;
    }
}

<h2>Doctor Time Slots</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (slots == null || slots.Count == 0)
{
    <p style="color:red;">No slots available.</p>
}
else
{
<table class="table table-bordered">

    <thead>
        <tr>
            <th>Date</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>

    @foreach (var slot in slots)
    {
        <tr>
            <td>@slot.SlotDate.ToString("dd-MM-yyyy")</td>

            <td>@To12Hour(slot.StartTime)</td>

            <td>@To12Hour(slot.EndTime)</td>

            <td>
                @if (slot.IsBooked)
                {
                    <span class="text-danger fw-bold">Booked</span>
                }
                else
                {
                    <span class="text-success fw-bold">Available</span>
                }
            </td>

            <td>
                @if (!slot.IsBooked)
                {
                    <form asp-controller="Appointment" asp-action="BookAppointment" method="post">

    <input type="hidden" name="doctorId" value="@Model.DoctorId" />

    <!-- 🔥 FORCE VALUE -->
    <input type="hidden" name="slotId" value="@Convert.ToInt32(slot.SlotId)" />

    <!-- DEBUG -->
    <span style="display:none;">SlotId: @slot.SlotId</span>

    <button type="submit" class="btn btn-success">
        Book Appointment
    </button>

</form>
                }
                else
                {
                    <button class="btn btn-secondary" disabled>
                        Not Available
                    </button>
                }
            </td>

        </tr>
    }

    </tbody>

</table>
}

<br/>

<a href="/Doctor" class="btn btn-primary">Back</a>