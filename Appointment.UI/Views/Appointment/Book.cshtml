@using Appointment.UI.Models
@model Appointment

@{
    ViewData["Title"] = "Book Appointment";
    List<TimeSlot>? slots = ViewBag.Slots as List<TimeSlot>;
}

<h2>Doctor Time Slots</h2>

@if (slots == null || slots.Count == 0)
{
    <p style="color:red;">No slots available.</p>
}
else
{

<table class="table table-bordered">

<thead>
<tr>
<th>Date</th>
<th>Start Time</th>
<th>End Time</th>
<th>Status</th>
<th>Action</th>
</tr>
</thead>

<tbody>

@foreach (var slot in slots)
{
<tr>

<td>@slot.SlotDate.ToString("dd-MM-yyyy")</td>

<td>@DateTime.Parse(slot.StartTime).ToString("hh:mm tt")</td>

<td>@DateTime.Parse(slot.EndTime).ToString("hh:mm tt")</td>

<td>
@if (slot.IsBooked)
{
<span style="color:red;font-weight:bold">Booked</span>
}
else
{
<span style="color:green;font-weight:bold">Available</span>
}
</td>

<td>

@if (!slot.IsBooked)
{
<form method="post" asp-action="BookAppointment">

<input type="hidden" name="doctorId" value="@Model.DoctorId" />
<input type="hidden" name="slotId" value="@slot.SlotId" />

<button type="submit" class="btn btn-success">
Book Appointment
</button>

</form>
}
else
{
<button class="btn btn-secondary" disabled>
Not Available
</button>
}

</td>

</tr>
}

</tbody>

</table>

}

<br/>

<a href="/Doctor" class="btn btn-primary">Back</a>