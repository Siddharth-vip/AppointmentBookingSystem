@model List<TimeSlot>

@functions {
    public static string To12Hour(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        if (TimeSpan.TryParse(value, out var timeSpanValue))
        {
            return DateTime.Today.Add(timeSpanValue).ToString("hh:mm tt");
        }

        if (DateTime.TryParse(value, out var dateTimeValue))
        {
            return dateTimeValue.ToString("hh:mm tt");
        }

        return value;
    }
}

<div class="container mt-5">

    <h2 class="text-center mb-4">Available Time Slots</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center">
            <p>No slots available</p>
        </div>
    }
    else
    {
        <div class="row">

            @foreach (var slot in Model.Where(s => !s.IsBooked))
            {
                <div class="col-md-4 mb-4">

                    <div class="card shadow-sm text-center p-3">

                        <h5>
                            @To12Hour(slot.StartTime) - @To12Hour(slot.EndTime)
                        </h5>

                        <form method="post" action="/Appointment/Book">
                            <input type="hidden" name="slotId" value="@slot.SlotId" />

                            <button class="btn btn-success mt-3">
                                Book Appointment
                            </button>
                        </form>

                    </div>

                </div>
            }

        </div>
    }

</div>